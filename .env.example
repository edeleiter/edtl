# =============================================================================
# Snowflake Connection — Unified ETL Platform
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.
# =============================================================================

# Your Snowflake account identifier
# (the part before .snowflakecomputing.com, e.g., abc12345.us-east-1)
SNOWFLAKE_ACCOUNT=

# -----------------------------------------------------------------------------
# Option A: Admin (your interactive user — for infrastructure work)
# -----------------------------------------------------------------------------
SNOWFLAKE_USER=YOUR_USERNAME
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=UNIFIED_ETL
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_SCHEMA_NAME=PUBLIC
SNOWFLAKE_ROLE=ETL_ADMIN

# -----------------------------------------------------------------------------
# Option B: Test runner (for pytest / CI) — uncomment and swap in
# -----------------------------------------------------------------------------
# SNOWFLAKE_USER=ETL_TEST_SVC
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_DATABASE=UNIFIED_ETL_TEST
# SNOWFLAKE_WAREHOUSE=TEST_WH
# SNOWFLAKE_SCHEMA_NAME=PUBLIC
# SNOWFLAKE_ROLE=ETL_TEST_RUNNER

# -----------------------------------------------------------------------------
# Option C: Deployer (for deploy.py) — uncomment and swap in
# -----------------------------------------------------------------------------
# SNOWFLAKE_USER=ETL_DEPLOY_SVC
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_DATABASE=UNIFIED_ETL
# SNOWFLAKE_WAREHOUSE=DEPLOY_WH
# SNOWFLAKE_SCHEMA_NAME=PUBLIC
# SNOWFLAKE_ROLE=ETL_DEPLOYER

# -----------------------------------------------------------------------------
# Option D: Trainer (for training pipeline) — uncomment and swap in
# -----------------------------------------------------------------------------
# SNOWFLAKE_USER=ETL_TRAIN_SVC
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_DATABASE=UNIFIED_ETL
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_SCHEMA_NAME=RAW
# SNOWFLAKE_ROLE=ETL_TRAINER

# -----------------------------------------------------------------------------
# DuckDB (defaults are fine for local dev — inference runs entirely on DuckDB)
# -----------------------------------------------------------------------------
# DUCKDB_DATABASE=:memory:
# DUCKDB_THREADS=4
